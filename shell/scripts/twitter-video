#!/usr/bin/env node
import { spawnSync } from "node:child_process";
import path from "node:path";

const input = process.argv[2];

if (!input) {
  console.error("Usage: twitter-video <input-video>");
  process.exit(1);
}

const parsed = path.parse(input);
const output = path.join(parsed.dir, `${parsed.name}-twitter.mp4`);

const args = [
  "-i", input,
  "-vf", "scale=1920:1080:flags=lanczos,unsharp=5:5:0.6:5:5:0.0",
  "-c:v", "libx264",
  "-profile:v", "high",
  "-level", "4.2",
  "-pix_fmt", "yuv420p",
  "-preset", "slow",
  "-b:v", "16M",
  "-maxrate", "16M",
  "-bufsize", "32M",
  "-r", "60",
  "-movflags", "+faststart",
  "-c:a", "aac",
  "-b:a", "192k",
  output,
];

console.log(`Converting:\n${input}\n→ ${output}`);

const result = spawnSync("ffmpeg", args, { stdio: "inherit" });

if (result.error) {
  console.error("Failed to run ffmpeg. Is ffmpeg installed and in PATH?");
  process.exit(1);
}

process.exit(result.status ?? 1);
